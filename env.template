# --- LLM provider (required) ---
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# --- Database (required in production) ---
# Managed providers (Railway, Heroku, …) inject DATABASE_URL automatically.
# A bare postgresql:// (or legacy postgres://) scheme is normalized to the
# async driver at runtime, so you can paste the provider's URL as-is.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Internal task API key (required in production) ---
# Gates /internal/tasks/* (job scraping, signal generation). The app refuses
# to start in non-DEBUG mode with this dev default. Generate with:
#   openssl rand -hex 32
INTERNAL_API_KEY=dev-internal-key

# --- App password (required in production) ---
# Shared secret gating the public /api/jobs* endpoints. The frontend sends it
# in the X-App-Password header. Change this from the default for any deploy.
APP_PASSWORD=letmein

# --- Debug mode (default: false) ---
# Set true for local development. Leave false/unset in production.
# DEBUG=true

# --- Job scraping (optional) ---
# Cron schedule for the recurring scrape-jobs task (default: every 6 hours).
# JOB_SCRAPE_CRON=0 */6 * * *
