# OpenAI Configuration
# Get your API key from: https://platform.openai.com/api-keys
# You can also use .env.local for local overrides (takes precedence over .env)
OPENAI_API_KEY=your_openai_api_key_here

# Database Configuration (optional)
# SQLite is used by default - no configuration required!
# The database will be created automatically at ./data/chatbot.db
#
# To use PostgreSQL instead, set:
# DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/chatbot

# Debug mode (default: false, set to true for local development)
# DEBUG=true

# Embedding deployment for the file-search index (search_files tool, index-documents task).
# When using Azure OpenAI: deployment name (e.g. "text-embedding-3-large").
# When using OpenAI: model name (e.g. "text-embedding-3-large").
# Truncated to 1536 dims (Matryoshka) for storage in pgvector.
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-large

# Internal API key for /internal endpoints (ingestion, signal generation).
# REQUIRED in production: app refuses to start in non-DEBUG mode with the
# dev default. Generate with: `openssl rand -hex 32`.
INTERNAL_API_KEY=dev-internal-key

# --- Job scraping ---
# Cron schedule for the periodic scrape-jobs task (default: every 6 hours).
# JOB_SCRAPE_CRON=0 */6 * * *
